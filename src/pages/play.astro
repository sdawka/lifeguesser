---
import GameView from '../components/GameView.vue';
import UserIdentityBar from '../components/UserIdentityBar.vue';
import '../styles/global.css';

const url = new URL(Astro.request.url);
// Parse comma-separated IDs (new format) or single IDs (backwards compat)
const taxaParam = url.searchParams.get('taxa') ?? url.searchParams.get('taxon');
const placesParam = url.searchParams.get('places') ?? url.searchParams.get('place');
const filters = {
  taxonIds: taxaParam ? taxaParam.split(',').map(Number).filter(Number.isFinite) : undefined,
  placeIds: placesParam ? placesParam.split(',').map(Number).filter(Number.isFinite) : undefined,
};
// Normalize empty arrays to undefined
if (filters.taxonIds?.length === 0) filters.taxonIds = undefined;
if (filters.placeIds?.length === 0) filters.placeIds = undefined;
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>LifeGuesser — Expedition in Progress</title>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin="" />
  </head>
  <body class="min-h-screen flex flex-col">
    <header class="px-6 md:px-10 pt-6">
      <div class="hairline"></div>
      <div class="flex items-center justify-between pt-3 text-[0.68rem] font-mono uppercase tracking-widest2 text-ink-soft">
        <span class="flex items-center gap-3">
          <a href="/" class="link-ink">← Index</a>
          <span class="opacity-40">|</span>
          <a href="/stats" class="link-ink">Archive</a>
          <span class="opacity-40">|</span>
          <a href="/leaderboard" class="link-ink">Leaderboard</a>
        </span>
        <span class="font-display italic text-base not-italic md:not-italic">
          <span class="italic font-light">Life</span><span class="font-semibold">Guesser</span>
        </span>
        <span class="flex items-center gap-3">
          <UserIdentityBar client:only="vue" />
          <span class="text-ink-soft">Expedition in Progress</span>
        </span>
      </div>
    </header>

    <main class="flex-1 px-4 md:px-10 pt-3 md:pt-4 pb-6 md:pb-4">
      <GameView client:only="vue" filters={filters} />
    </main>
  </body>
</html>
