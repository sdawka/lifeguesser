{
  "name": "lifeguesser",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "test": "vitest",
    "astro": "astro",
    "deploy": "astro build && wrangler pages deploy dist --project-name lifeguesser --branch main --commit-dirty=true",
    "db:migrate": "wrangler d1 execute lifeguesser-db --remote --file",
    "db:seed": "npx tsx scripts/populate-observations.ts"
  },
  "dependencies": {
    "astro": "^4.16.0",
    "@astrojs/cloudflare": "^11.0.0",
    "@astrojs/vue": "^4.5.0",
    "@astrojs/tailwind": "^5.1.0",
    "vue": "^3.4.0",
    "leaflet": "^1.9.4",
    "tailwindcss": "^3.4.0"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.12",
    "typescript": "^5.6.0",
    "vitest": "^1.6.0",
    "@cloudflare/workers-types": "^4.20240909.0"
  }
}
